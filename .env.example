# ===========================================================================
# Coodra — Environment Variables (example)
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values for your environment.
# Never commit `.env`. Dev values below are solo-mode safe (local loopback).
# Required-at-startup vars are validated by packages/shared/src/config.ts
# via Zod; a service that needs a missing required var fails fast.
# ===========================================================================

# --- Mode ------------------------------------------------------------------
# Controls whether local services write to SQLite (solo) or Postgres (team).
# Values: "solo" | "team". Default: "solo".
COODRA_MODE=solo

# --- Logging ---------------------------------------------------------------
# pino log level. Values: "debug" | "info" | "warn" | "error". Default: "info".
LOG_LEVEL=info

# --- Service ports (local dev) --------------------------------------------
MCP_SERVER_PORT=3100
HOOKS_BRIDGE_PORT=3101
WEB_APP_PORT=3000
NL_ASSEMBLY_PORT=3200
SEMANTIC_DIFF_PORT=3201

# --- SQLite (solo mode) ----------------------------------------------------
# Path to the local SQLite file. Default: ~/.coodra/data.db (expanded at
# runtime). Override only for test isolation.
# COODRA_SQLITE_PATH=

# --- MCP server DB dialect override (local-dev) ----------------------------
# Override the env-derived team→Postgres routing in createDb. Set to 'solo'
# to run the team-mode auth chain locally with a SQLite store (useful for
# verifying the auth surface without standing up Postgres). Leave unset for
# normal deploys.
# COODRA_DB_OVERRIDE_MODE=

# --- MCP server local-state roots ------------------------------------------
# Override on-disk roots for context-pack materialisation and Graphify
# index lookups. Defaults are <cwd>/docs/context-packs and
# ~/.coodra/graphify respectively. Set these when running the binary
# from a directory that isn't the repo root.
# COODRA_CONTEXT_PACKS_ROOT=
# COODRA_GRAPHIFY_ROOT=

# --- Postgres (team mode) --------------------------------------------------
# Supabase / managed Postgres with pgvector extension enabled.
# Required when COODRA_MODE=team.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/coodra

# --- Redis (team mode) -----------------------------------------------------
# Upstash or compatible Redis URL. Required when COODRA_MODE=team.
# REDIS_URL=redis://localhost:6379

# --- Auth (Clerk) ----------------------------------------------------------
# Solo-mode bypass value is honoured explicitly by the auth middleware — see
# essentialsforclaude/02-agent-human-boundary.md §2.4 and
# system-architecture.md §19. Replace with a real Clerk secret before
# enabling team-mode auth (Module 04+).
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# --- Local hook secret (team mode) ----------------------------------------
# Generated on first `coodra team login` and stored in ~/.coodra/config.json.
# Used by the Windsurf adapter script to authenticate to the cloud Hooks Bridge.
# Do NOT reuse across machines. Do NOT commit.
# LOCAL_HOOK_SECRET=

# --- LLM providers (Modules 05 / 06) --------------------------------------
# At least one provider is required for NL Assembly Tier-3 enrichment and
# Semantic Diff narrative. Anthropic is the primary; Gemini and OpenAI are
# fallbacks. Solo-mode Ollama is discovered automatically and needs no key.
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# --- GitHub integration (§23) ---------------------------------------------
# Populated when the GitHub App is registered. Module 02 reads these when
# GitHub tools are implemented. Never commit the PEM; store the path or the
# secret-manager handle here.
# GITHUB_APP_ID=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_WEBHOOK_SECRET=
# GITHUB_PRIVATE_KEY_PATH=

# --- Atlassian / JIRA integration (§22) -----------------------------------
# Populated when the Atlassian OAuth 2.0 (3LO) app is registered.
# ATLASSIAN_CLIENT_ID=
# ATLASSIAN_CLIENT_SECRET=
# ATLASSIAN_WEBHOOK_SECRET=

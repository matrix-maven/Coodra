# --- Node / pnpm / Turborepo ---
node_modules/
.pnpm-store/
.pnpm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/

# --- Build output ---
dist/
build/
out/
.next/
.nuxt/
.output/
.vercel/
.svelte-kit/
.cache/
coverage/
*.tsbuildinfo
*.tsbuildinfo.*

# --- TypeScript / Vite / Vitest ---
*.log
.vitest-cache/
.vite/

# --- Environments & secrets ---
.env
.env.*
!.env.example
.envrc

# --- Python (services/) ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
.env.venv/
.ruff_cache/
.pytest_cache/
.mypy_cache/
.uv/
uv.lock.local

# --- Databases / local state ---
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*.db
data/
/data.db

# --- Coodra local runtime ---
.coodra/
# F13 closure (verification 2026-04-27): save_context_pack now defaults
# to ~/.coodra/packs/ (out of repo). Defensive entry below catches
# any agent that overrides COODRA_CONTEXT_PACKS_ROOT to point at
# this repo. Hand-named module closeouts (no `-run-` segment) stay
# tracked in docs/context-packs/.
docs/context-packs/*-run-*.md

# --- IDE & editor ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.sample.json
.idea/
*.swp
*.swo
*.iml

# --- Claude Code local state (per-machine, never committed) ---
.claude/

# --- OS junk ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Logs ---
logs/
*.log
# Don't ignore intentional source `logs/` directories under apps/.
!apps/**/app/**/logs/
!apps/**/app/**/logs/**

# --- Drizzle local artefacts kept out of git (generated files live in packages/db/drizzle/ and ARE committed) ---
drizzle/.journal/tmp/
supabase/.temp/

# npm pack tarballs
*.tgz

# --- Internal artifacts: kept on each maintainer's machine, excluded from the public repo ---
# AI-agent operating rules + per-session working memory (used locally, not shipped)
/CLAUDE.md
/essentialsforclaude/
/context_memory/
# Presentation / stakeholder-demo materials
/presentation/

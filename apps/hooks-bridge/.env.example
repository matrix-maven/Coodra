# @coodra/hooks-bridge — example environment file
#
# Copy to .env (git-ignored via the root .gitignore) for local runs.
# The `dev` npm script already sets COODRA_LOG_DESTINATION=stderr.

# --- Required for every run -------------------------------------------
COODRA_LOG_DESTINATION=stderr
COODRA_MODE=solo
LOG_LEVEL=info

# --- Hooks Bridge HTTP listener ---------------------------------------
# Bound to loopback in solo mode by default. Team operators set HOST
# explicitly (e.g. 0.0.0.0 behind a reverse proxy).
HOOKS_BRIDGE_HOST=127.0.0.1
HOOKS_BRIDGE_PORT=3101

# --- Auth chain (carried forward from mcp-server's contract) ----------
# In solo mode the sentinel below activates the bypass branch and Clerk
# keys are not required. Team mode rejects the sentinel and demands a
# real sk_test_/sk_live_ key + a pk_test_/pk_live_ key.
LOCAL_HOOK_SECRET=
CLERK_SECRET_KEY=sk_test_replace_me
# CLERK_PUBLISHABLE_KEY=
# CLERK_JWT_ISSUER=

# --- Local SQLite path (Module 03 S4: local services always SQLite) ---
# Override only when running outside the repo or for test isolation.
# Defaults to ~/.coodra/data.db.
# COODRA_SQLITE_PATH=

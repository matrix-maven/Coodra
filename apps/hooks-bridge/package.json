{
  "name": "@coodra/hooks-bridge",
  "version": "0.0.0",
  "private": true,
  "description": "Coodra Hooks Bridge — Hono service on 127.0.0.1:3101 that ingests Claude Code (HTTP), Windsurf (shell adapter), and Cursor (shell adapter) hook events, normalizes them through per-agent adapters, runs pre-tool policy enforcement, and writes runs + run_events.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "coodra-hooks-bridge": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check .",
    "dev": "COODRA_LOG_DESTINATION=stderr tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@coodra/cli": "workspace:*",
    "@coodra/db": "workspace:*",
    "@coodra/policy": "workspace:*",
    "@coodra/shared": "workspace:*",
    "@hono/node-server": "2.0.0",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.21.0"
  }
}

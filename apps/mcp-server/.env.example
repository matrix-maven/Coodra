# @coodra/mcp-server — example environment file
#
# Copy to .env (git-ignored via the root .gitignore) for local runs. The
# `dev` npm script already sets COODRA_LOG_DESTINATION=stderr for you;
# if you invoke `node dist/index.js` directly, you MUST export it first
# or stdio transport will be corrupted by stray log bytes.

# --- Required for every run -------------------------------------------
# Always 'stderr' for the mcp-server. 'stdout' would corrupt stdio
# JSON-RPC frames. Unknown values fail fast at startup.
COODRA_LOG_DESTINATION=stderr

# --- From packages/shared env (COODRA_MODE, LOG_LEVEL, etc.) -------
COODRA_MODE=solo
LOG_LEVEL=info

# --- Reserved for later slices ----------------------------------------
# These are consumed by src/config/env.ts but optional in solo mode /
# in S5 (stdio only). See `docs/feature-packs/02-mcp-server/` for the
# full contract.
#
# MCP_SERVER_PORT=3100
# LOCAL_HOOK_SECRET=
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=sk_test_replace_me
# CLERK_JWT_ISSUER=

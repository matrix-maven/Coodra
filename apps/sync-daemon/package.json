{
  "name": "@coodra/sync-daemon",
  "version": "0.0.0",
  "private": true,
  "description": "Coodra Sync Daemon — third managed process in team mode. Drains pending_jobs sync_to_cloud rows from local SQLite and pushes the referenced row into cloud Postgres. Module 04a.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "coodra-sync-daemon": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check .",
    "dev": "COODRA_LOG_DESTINATION=stderr tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@coodra/cli": "workspace:*",
    "@coodra/db": "workspace:*",
    "@coodra/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.21.0"
  }
}

{
  "name": "@coodra/contextos-web",
  "version": "0.0.0",
  "private": true,
  "description": "ContextOS Web App — Next.js 15 admin + audit-trail UI. Same build in solo (against ~/.contextos/data.db via better-sqlite3) and team (against Supabase Postgres + Clerk JWT). M04 per docs/feature-packs/04-web-app/.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3000",
    "start": "next start --port 3000",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next .turbo"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.13.4",
    "@coodra/contextos-db": "workspace:*",
    "@coodra/contextos-shared": "workspace:*",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.4",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "happy-dom": "^15.11.0",
    "tailwindcss": "^4.1.13",
    "vitest": "^4.1.5"
  }
}

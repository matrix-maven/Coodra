# Coodra team-mode self-host environment template.
# Copy to deploy/.env and fill in the required values.

# ──────────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────────

# DATABASE_URL — points the cloud-migrate one-shot + the three services
# at your team's Postgres. The Compose stack ships a postgres service
# at host=postgres (Docker DNS resolves the service name); use this
# default if you don't have a managed Postgres yet.
DATABASE_URL=postgres://coodra:changeme@postgres:5432/coodra

# LOCAL_HOOK_SECRET — shared between hooks-bridge and the agents that
# fire hooks at it. Generate a fresh random value per deploy:
#   openssl rand -hex 32
LOCAL_HOOK_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Optional overrides
# ──────────────────────────────────────────────────────────────────────

# Postgres credentials when the Compose stack manages its own postgres.
POSTGRES_USER=coodra
POSTGRES_PASSWORD=changeme
POSTGRES_DB=coodra
POSTGRES_PORT=5432

# Service ports on the host. Internal container ports are fixed
# (3100 mcp-server, 3101 hooks-bridge).
MCP_SERVER_PORT=3100
HOOKS_BRIDGE_PORT=3101

# Sync-daemon tuning. Defaults match M03.1's audit-write OutboxWorker
# so operators have one number to remember (30s lease).
COODRA_SYNC_TICK_MS=1000
COODRA_SYNC_LEASE_MS=30000

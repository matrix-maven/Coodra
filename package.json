{
  "name": "coodra",
  "version": "0.0.0",
  "private": true,
  "description": "Coodra — MCP server platform providing Feature Packs, Context Packs, and policy enforcement for AI coding agents.",
  "license": "MIT",
  "author": "Abishai <abishai95141@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matrix-maven/Coodra.git"
  },
  "homepage": "https://github.com/matrix-maven/Coodra#readme",
  "bugs": {
    "url": "https://github.com/matrix-maven/Coodra/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.16.0 <23",
    "pnpm": ">=10.33.0 <11"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm test:unit",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:functional": "bash __tests__/functional/run-all.sh",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@coodra/cli": "workspace:*",
    "@coodra/db": "workspace:*",
    "@coodra/hooks-bridge": "workspace:*",
    "@coodra/mcp-server": "workspace:*",
    "@coodra/policy": "workspace:*",
    "@coodra/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "testcontainers": "11.14.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome",
      "better-sqlite3",
      "@clerk/shared"
    ]
  }
}

{
  "name": "@contextos/cli",
  "version": "0.0.0",
  "private": true,
  "description": "ContextOS CLI — single-binary install/configure/run/diagnose surface for solo and team modes. Module 08a.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "contextos": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.16.0 <23"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abishai95141/Coodra.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Abishai95141/Coodra/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/Abishai95141/Coodra/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "//build": "executable bit on dist/index.js is set by `npm publish` from the `bin` field; do not add a postbuild chmod (noise for zero real value — we always invoke via `node dist/index.js` in workspace dev)",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check .",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "cli": "node dist/index.js",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@contextos/db": "workspace:*",
    "@contextos/shared": "workspace:*",
    "commander": "^13.1.0",
    "env-paths": "^3.0.0",
    "execa": "^9.6.0",
    "glob": "^11.0.4",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tmp-promise": "^3.0.3",
    "tsx": "^4.21.0"
  }
}

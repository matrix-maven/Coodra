{
  "name": "@coodra/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared primitives for Coodra: structured logger, typed errors, Zod env parsing, idempotency-key helpers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./idempotency": {
      "types": "./dist/idempotency.d.ts",
      "import": "./dist/idempotency.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./context-pack-paths": {
      "types": "./dist/context-pack-paths.d.ts",
      "import": "./dist/context-pack-paths.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/index.d.ts",
      "import": "./dist/test-utils/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./features": {
      "types": "./dist/features/index.d.ts",
      "import": "./dist/features/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check .",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clerk/backend": "3.3.0",
    "pino": "^10.3.1",
    "yaml": "^2.8.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "pino-pretty": "^13.1.3"
  }
}

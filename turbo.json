{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", "biome.json", ".env"],
  "globalEnv": ["NODE_ENV", "COODRA_MODE", "LOG_LEVEL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!dist/**/*.test.*", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "../../tsconfig.base.json"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "../../biome.json"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$"],
      "env": ["COODRA_MODE", "CLERK_SECRET_KEY"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$"],
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "COODRA_MODE",
        "CLERK_SECRET_KEY",
        "CLERK_PUBLISHABLE_KEY",
        "CLERK_JWT_ISSUER",
        "LOCAL_HOOK_SECRET",
        "MCP_SERVER_HOST",
        "MCP_SERVER_PORT",
        "MCP_SERVER_TRANSPORT"
      ]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$"],
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "COODRA_MODE",
        "CLERK_SECRET_KEY",
        "CLERK_PUBLISHABLE_KEY",
        "CLERK_JWT_ISSUER",
        "LOCAL_HOOK_SECRET",
        "MCP_SERVER_HOST",
        "MCP_SERVER_PORT",
        "MCP_SERVER_TRANSPORT",
        "DOCKER_HOST",
        "TESTCONTAINERS_HOST_OVERRIDE"
      ]
    },
    "clean": {
      "cache": false,
      "outputs": []
    }
  }
}
